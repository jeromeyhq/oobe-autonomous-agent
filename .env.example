# OOBE Protocol RPC URL (get from https://synapse.oobeprotocol.ai/)
OOBE_RPC_URL=https://us-1-mainnet.oobeprotocol.ai/rpc?api_key=YOUR_API_KEY

# Solana Wallet Keypair Path
WALLET_KEYPAIR_PATH=./keys/agent-keypair.json

# Ace Data Cloud API Key (get from https://platform.acedata.cloud)
ACE_DATA_CLOUD_API_KEY=sk_live_YOUR_API_KEY

# Agent Configuration
AGENT_NAME=DataForge-Agent
AGENT_DESCRIPTION=Autonomous data intelligence agent powered by Ace Data Cloud with multi-service orchestration
